# ==================================
# DATABASE CONFIGURATION
# ==================================

# Database password used by docker-compose and backend datasource
DB_PASSWORD=change_this_password

# Spring profile for local XAMPP MySQL
SPRING_PROFILES_ACTIVE=xampp

# MySQL/XAMPP datasource (backend)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/esprit_activities?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

# PostgreSQL connection string (optional for non-docker local tools)
DATABASE_URL=postgresql://esprit_user:change_this_password@localhost:5432/esprit_activities

# ==================================
# JWT & AUTHENTICATION
# ==================================

# Secret key for JWT token signing (minimum 32 characters)
# Generate with: openssl rand -base64 48
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_change_this_in_production

# JWT token expiration time
JWT_EXPIRES_IN=7d

# CORS and login protection
ALLOWED_ORIGINS=http://localhost:4200
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Bcrypt rounds for password hashing (10-12 recommended)
BCRYPT_ROUNDS=12

# ==================================
# APPLICATION SETTINGS
# ==================================

# Spring profile
SPRING_PROFILES_ACTIVE=docker

# Backend server port
SERVER_PORT=8080

# Angular frontend URL
FRONTEND_URL=http://localhost:4200

# Application name
NEXT_PUBLIC_APP_NAME=ESPRIT Activities Platform

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:4200

# ==================================
# EMAIL CONFIGURATION (SMTP)
# ==================================

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL, 25 for non-secure)
SMTP_PORT=587

# Use secure connection (true/false)
SMTP_SECURE=false

# SMTP authentication username (email address)
SMTP_USER=noreply@esprit.tn

# SMTP authentication password (app-specific password for Gmail)
SMTP_PASSWORD=your_smtp_password_here

# Email sender address and name
SMTP_FROM=ESPRIT Activities <noreply@esprit.tn>

# ==================================
# FILE STORAGE
# ==================================

# Local file upload directory (absolute path)
UPLOAD_DIR=./public/uploads

# Maximum file size in bytes (50MB default)
MAX_FILE_SIZE=52428800

# ==================================
# AWS S3 (Optional - for cloud storage)
# ==================================

# AWS credentials
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=esprit-activities-files

# ==================================
# LOGGING & MONITORING
# ==================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ==================================
# RATE LIMITING
# ==================================

# Time window in milliseconds (15 minutes default)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ==================================
# CORS CONFIGURATION
# ==================================

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==================================
# REDIS (Optional - for caching)
# ==================================

# Redis connection URL
# REDIS_URL=redis://localhost:6379

# ==================================
# FEATURES FLAGS
# ==================================

# Enable/disable specific features
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PDF_GENERATION=true
ENABLE_EXCEL_EXPORT=true

# ==================================
# ACADEMIC YEAR SETTINGS
# ==================================

# Current academic year (format: YYYY-YYYY)
CURRENT_ACADEMIC_YEAR=2023-2024

# Academic year start date (format: YYYY-MM-DD)
ACADEMIC_YEAR_START=2023-09-01

# Academic year end date (format: YYYY-MM-DD)
ACADEMIC_YEAR_END=2024-06-30

# ==================================
# DEVELOPMENT TOOLS
# ==================================

# Enable debug mode (true/false)
DEBUG=false

# Enable SQL query logging (true/false)
LOG_SQL_QUERIES=false

# ==================================
# PRODUCTION ONLY
# ==================================

# In production, make sure to:
# 1. Change JWT_SECRET to a strong random value
# 2. Set NODE_ENV=production
# 3. Use secure DATABASE_URL with strong password
# 4. Configure proper SMTP credentials
# 5. Set ALLOWED_ORIGINS to your production domain
# 6. Enable HTTPS
# 7. Consider using environment variables from hosting provider
